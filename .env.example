# LangSmith API key (required for LangSmith provider)
LANGSMITH_API_KEY=

# Load Testing Configuration
# Required: Authorization header for SUT requests
LOADTEST_SUT_AUTH_HEADER=
# Required: URL where SUT accepts login requests
LOADTEST_SUT_LOGIN_URL=https://your-sut-api.com/api/v1/chat/login
# Required: URL where SUT accepts message requests
LOADTEST_SUT_SUBMIT_URL=https://your-sut-api.com/api/v1/chat/messages

# LLM Resources (numbered 1-5, resources with empty BASE_URL are skipped)
LLM_RESOURCE_1_BASE_URL=https://your-resource.openai.azure.com
LLM_RESOURCE_1_API_KEY=
LLM_RESOURCE_1_PROVIDER=gpt
LLM_RESOURCE_1_DEPLOYMENTS=gpt-5.4,gpt-4o-mini

LLM_RESOURCE_2_BASE_URL=
LLM_RESOURCE_2_API_KEY=
LLM_RESOURCE_2_PROVIDER=claude
LLM_RESOURCE_2_DEPLOYMENTS=claude-sonnet-4-6,claude-haiku

# Active LLM settings (overridable from Locust UI)
LLM_DEPLOYMENT=gpt-5.4
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
